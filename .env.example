# Supabase Postgres via Prisma (Supabase dashboard → Settings → Database)
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_ID:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_ID:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# Supabase JWT secret (Supabase dashboard → Settings → API → JWT Secret)
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# Supabase Admin (for seed script)
SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

PORT=8000
