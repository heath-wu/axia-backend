{
  "name": "axia-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "test": "tsx --test test/**/*.test.ts",
    "start": "node dist/server.js",
    "postinstall": "prisma generate",
    "db:push": "prisma db push && npm run db:backfill-tenants && npm run db:constraints",
    "db:backfill-tenants": "tsx scripts/backfill-tenant-ownership.ts",
    "db:constraints": "tsx scripts/apply-db-constraints.ts",
    "db:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.45.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
